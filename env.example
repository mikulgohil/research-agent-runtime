# ──────────────────────────────────────────────────────────────────────────
# Research Agent Runtime — environment configuration
# Copy to `.env.local` and adjust. Every value has a safe default, so the app
# runs with ZERO configuration (local file storage + deterministic mock model).
#
#   cp env.example .env.local
# ──────────────────────────────────────────────────────────────────────────

# Storage driver: "local" (JSON file under ./.data) or "supabase"
STORAGE_DRIVER=local

# Model driver: "mock" (deterministic, no API key) or "anthropic" (live Claude)
MODEL_DRIVER=mock

# ── Anthropic (only needed when MODEL_DRIVER=anthropic) ─────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# Model id used for planning + report generation
ANTHROPIC_MODEL=claude-opus-4-8

# ── Supabase (only needed when STORAGE_DRIVER=supabase) ─────────────────────
# Run supabase/migrations/0001_init.sql against your project first.
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
